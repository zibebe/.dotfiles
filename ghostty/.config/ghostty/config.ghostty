# Theme
theme = "Modus Vivendi Tinted"

# Font
font-family = "Codelia Ligatures"
font-size = 18

# Window
window-padding-x = 8
window-padding-y = 4
window-padding-balance = true
adjust-cell-height = 10

# macOS
macos-titlebar-style = tabs
macos-option-as-alt = left

# Others
shell-integration-features = ssh-env
